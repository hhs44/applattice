{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://testing.intra.example.com/schemas/service-catalog.schema.json",
  "title": "Testing platform service catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "services"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "owner",
          "runtime",
          "repository",
          "gateway",
          "contract",
          "deployment",
          "development"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "title": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "runtime": { "enum": ["node", "python", "external"] },
          "repository": { "type": "string", "minLength": 1 },
          "gateway": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "baseUrlEnv",
              "developmentUrl",
              "containerUrl",
              "healthPath",
              "requestTimeoutMs",
              "required"
            ],
            "properties": {
              "baseUrlEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "developmentUrl": { "type": "string", "pattern": "^https?://" },
              "containerUrl": { "type": "string", "pattern": "^https?://" },
              "healthPath": { "type": "string", "pattern": "^/" },
              "requestTimeoutMs": { "type": "integer", "minimum": 100 },
              "required": { "type": "boolean" }
            }
          },
          "contract": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version", "source"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
              "source": { "type": "string", "minLength": 1 }
            }
          },
          "deployment": {
            "type": "object",
            "additionalProperties": false,
            "required": ["imageEnv", "image", "containerPort", "environment", "healthcheckCommand"],
            "properties": {
              "imageEnv": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "image": { "type": "string", "minLength": 1 },
              "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "environment": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "healthcheckCommand": {
                "type": "array",
                "minItems": 2,
                "items": { "type": "string" }
              }
            }
          },
          "development": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fallbackPath", "dockerfile"],
            "properties": {
              "fallbackPath": { "type": "string", "minLength": 1 },
              "dockerfile": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
