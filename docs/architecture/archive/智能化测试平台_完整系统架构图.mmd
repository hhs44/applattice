  QUALITY --> LABEL --> FEATURE --> MINING
  CATALOG --> SCENE
  CATALOG --> SIGNAL
  CATALOG --> DATASET
  CATALOG --> KNOWLEDGE
  CATALOG --> EVIDENCE
  DOMAIN <--> CATALOG
  MINING --> SCENE
  MINING --> KNOWLEDGE
  SYNC --> SIGNAL
  LABEL --> DATASET
  D5 --> EVIDENCE
  TRACE --> EVIDENCE
  RAG <--> KNOWLEDGE
  RAG <--> SCENE
  ORCH --> RDB
  DOMAIN --> RDB
  AISTATE --> RDB
  AISTATE --> CACHE
  INGEST --> LAKE
  SYNC --> TSDB
  FEATURE --> LAKE
  FEATURE --> VECTOR
  RAG <--> VECTOR
  KNOWLEDGE --> GRAPH
  CATALOG --> RDB
  IDP --> SECURITY
  DEVOPS --> DELIVERY
  OBS --> NOTICE
