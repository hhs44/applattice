# 开发模式仅允许在非 production 环境使用，通过请求头模拟企业身份。
AUTH_MODE=dev
PORTAL_ORIGIN=http://localhost:5173
GATEWAY_PORT=4000
DOMAIN_SERVICE_PORT=4100
DOMAIN_SERVICE_URL=http://localhost:4100

# 多上游场景优先由 pnpm hybrid:render 生成；显式设置时会覆盖 DOMAIN_SERVICE_URL。
# UPSTREAMS_JSON={"domain-service":{"baseUrl":"http://localhost:4100","healthPath":"/health/ready","requestTimeoutMs":5000,"required":true}}

# 生产环境把 AUTH_MODE 改为 oidc，并配置企业身份提供方。
# AUTH_MODE=oidc
# OIDC_ISSUER=https://sso.intra.example.com/realms/applattice
# OIDC_AUDIENCE=applattice
# OIDC_JWKS_URL=https://sso.intra.example.com/realms/applattice/protocol/openid-connect/certs
