# 开发/演示部署：不连接企业 SSO，只允许用于隔离的非生产环境。
NODE_ENV=development
AUTH_MODE=dev
PORTAL_PORT=8080
PORTAL_ORIGIN=http://localhost:8080

# 内网镜像仓库中的基础镜像。上线前应固定到企业批准的 digest。
NODE_IMAGE=node:22-alpine
NGINX_IMAGE=nginx:1.27-alpine
GATEWAY_IMAGE=intelligent-testing/gateway:0.1.0
PORTAL_IMAGE=intelligent-testing/portal:0.1.0
DOMAIN_SERVICE_IMAGE=intelligent-testing/domain-service:0.1.0

# 多仓服务拓扑由 pnpm hybrid:render 根据 platform/service-catalog.json 生成。
# 不要在这里提交包含凭据的服务 URL；生产环境应由配置中心或发布系统注入。

# 生产部署：设置 NODE_ENV=production、AUTH_MODE=oidc 并填写以下三项。
# OIDC_ISSUER=https://sso.intra.example.com/realms/testing
# OIDC_AUDIENCE=testing-platform
# OIDC_JWKS_URL=https://sso.intra.example.com/realms/testing/protocol/openid-connect/certs
