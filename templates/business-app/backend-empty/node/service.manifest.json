{
  "schemaVersion": 1,
  "id": "__SERVICE_ID__",
  "title": "__SERVICE_TITLE__",
  "owner": "CHANGE_ME",
  "runtime": "node",
  "port": "__PORT_NUMBER__",
  "repository": "ssh://git.intra.example.com/business-apps/__SERVICE_ID__.git",
  "apiBasePath": "/api/v1",
  "healthPath": "/health/ready",
  "contract": {
    "name": "__SERVICE_ID__-api",
    "version": "1.0.0",
    "path": "contracts/openapi.json"
  },
  "deployment": {
    "image": "business/__SERVICE_ID__:1.0.0",
    "environment": { "SERVICE_PORT": "__PORT__" },
    "healthcheckCommand": [
      "CMD",
      "node",
      "-e",
      "fetch('http://127.0.0.1:__PORT__/health/ready').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
    ]
  }
}
